{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DBGuardX",
  "version": "1.0.0",
  "identifier": "com.dbguardx.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DBGuardX",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "visible": false,
        "center": true
      },
      {
        "label": "splash",
        "title": "Loading...",
        "width": 500,
        "height": 450,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "url": "index.html#/splash",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "DB Backup Manager"
  }
}
